@model IEnumerable<SecureCommunicationApp.Models.ChatGroup>

<h2>Chat Groups</h2>

<a asp-action="Create" class="btn btn-success mb-2">Create New Group</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Group Name</th>
            <th>Description</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.GroupName</td>
                <td>@item.Description</td>
                <td>@item.CreatedAt</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ChatGroupId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Details" asp-route-id="@item.ChatGroupId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Delete" asp-route-id="@item.ChatGroupId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>