@model SecureCommunicationApp.Models.ChatGroup

<h2>Delete Chat Group</h2>

<h4>Are you sure you want to delete this group?</h4>

<div class="mb-3">
    <strong>Group Name:</strong> @Model.GroupName <br />
    <strong>Description:</strong> @Model.Description <br />
    <strong>Created At:</strong> @Model.CreatedAt
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ChatGroupId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>