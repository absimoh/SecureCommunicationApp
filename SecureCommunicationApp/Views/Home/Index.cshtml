<h1 class="mb-4">Secure Communication Dashboard</h1>

<div class="row">

    <div class="col-md-4">
        <div class="card p-3 shadow">
            <h3>Users</h3>
            <h2>@ViewBag.UsersCount</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow">
            <h3>Messages</h3>
            <h2>@ViewBag.MessagesCount</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card p-3 shadow">
            <h3>Groups</h3>
            <h2>@ViewBag.GroupsCount</h2>
        </div>
    </div>

</div>

<hr />

<p>Welcome to Secure Communication System. Manage users, messages, and groups securely.</p>