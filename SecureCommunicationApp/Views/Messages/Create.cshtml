@model SecureCommunicationApp.Models.Message

<h2>Send Message</h2>

<form asp-action="Create" method="post" class="w-50">

    <div class="mb-2">
        <label asp-for="Content"></label>
        <input asp-for="Content" class="form-control" />
        <span asp-validation-for="Content" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="SenderId"></label>
        <select asp-for="SenderId" class="form-control" asp-items="ViewBag.SenderId"></select>
        <span asp-validation-for="SenderId" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="ReceiverId"></label>
        <select asp-for="ReceiverId" class="form-control" asp-items="ViewBag.ReceiverId"></select>
        <span asp-validation-for="ReceiverId" class="text-danger"></span>
    </div>

    <div class="mb-2">
        <label asp-for="IsRead"></label>
        <input asp-for="IsRead" class="form-check-input" />
        <span asp-validation-for="IsRead" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Send</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}