@model SecureCommunicationApp.Models.Message

<h2>Delete Message</h2>

<h4>Are you sure you want to delete this message?</h4>

<div class="mb-3">
    <strong>Content:</strong> @Model.Content <br />
    <strong>Sender:</strong> @Model.Sender?.FullName <br />
    <strong>Receiver:</strong> @Model.Receiver?.FullName <br />
    <strong>Sent Date:</strong> @Model.SentDate
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="MessageId" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>